#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="${APP_DIR}/data"
TARGET_CONFIG_DIR="${APP_DATA_DIR}/config"
TARGET_TRANSCODE_DIR="${APP_DATA_DIR}/transcode"
DOWNLOADS_DIR="${UMBREL_ROOT}/home/Downloads"
VORTEXO_LIBRARY_DIR="${DOWNLOADS_DIR}/vortexo"

if command -v sysctl >/dev/null 2>&1; then
  sysctl -w fs.inotify.max_user_watches=1048576 >/dev/null 2>&1 || true
  sysctl -w fs.inotify.max_user_instances=2048 >/dev/null 2>&1 || true
  sysctl -w fs.inotify.max_queued_events=32768 >/dev/null 2>&1 || true
fi

mkdir -p "${TARGET_CONFIG_DIR}" "${TARGET_TRANSCODE_DIR}" "${DOWNLOADS_DIR}" "${VORTEXO_LIBRARY_DIR}"

chown -R 1000:1000 "${TARGET_CONFIG_DIR}" "${TARGET_TRANSCODE_DIR}"
