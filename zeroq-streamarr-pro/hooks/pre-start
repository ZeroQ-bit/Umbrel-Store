#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(readlink -f "$(dirname "${BASH_SOURCE[0]}")/..")"
APP_DATA_DIR="${APP_DIR}/data"
DOWNLOADS_DIR="${UMBREL_ROOT}/home/Downloads"
LIBRARY_DIR="${DOWNLOADS_DIR}/vortexo"
MOUNT_DIR="${DOWNLOADS_DIR}/.vortexo-source"

mkdir -p "${APP_DATA_DIR}"
mkdir -p "${DOWNLOADS_DIR}" "${LIBRARY_DIR}"

if ! stat "${MOUNT_DIR}" >/dev/null 2>&1; then
  echo "Preparing Debrid WebDAV mount path at ${MOUNT_DIR}"
  fusermount3 -uz "${MOUNT_DIR}" 2>/dev/null || true
  fusermount -uz "${MOUNT_DIR}" 2>/dev/null || true
  umount -l "${MOUNT_DIR}" 2>/dev/null || true
  rm -rf "${MOUNT_DIR}" 2>/dev/null || true
fi

mkdir -p "${MOUNT_DIR}"

if ! mountpoint -q "${MOUNT_DIR}"; then
  mount --bind "${MOUNT_DIR}" "${MOUNT_DIR}"
fi

PROPAGATION="$(findmnt -T "${MOUNT_DIR}" -o PROPAGATION -n 2>/dev/null || true)"
if [[ "${PROPAGATION}" != "shared" && "${PROPAGATION}" != "rshared" ]]; then
  mount --make-rshared "${MOUNT_DIR}"
fi

if [[ ! -e /dev/fuse ]]; then
  echo "Warning: /dev/fuse is not available on this Umbrel host. Vortexo Server will not be able to mount its Debrid WebDAV library." >&2
fi
